function solution(n_str) {
    let i = 0; > 반복하면서 빼야하니까 변수를 0으로 지정

    while (n_str[i] === '0') {
        i++; > 조건이 맞을 때까지 빼야하고 i가 인덱스니까 []에 넣고, === 0이 참일때 다음으로 넘어가야해. 참이 아닐때 다음단계로 넘어가고 
    }

    return n_str.slice(i); > i의 인덱스부터 거기서부터 잘라서 출력해
}


